# =============================================================================
# Openclaw Railway Template - Environment Variables
# =============================================================================
# Copy this file to .env for local development
# For Railway deployment, set these in the Railway dashboard Variables section
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED VARIABLES
# -----------------------------------------------------------------------------

# Password to access the /setup wizard (min 12 chars recommended for production)
# For Railway: Use ${{ secret(32) }} to generate a random secure password
# For local: Set any password you want
SETUP_PASSWORD=your-secure-password-here

# Directory where openclaw stores configuration and state
# MUST point to /data on Railway (volume mount) for persistence
OPENCLAW_STATE_DIR=/data/.openclaw

# Directory where openclaw stores workspace files
# MUST point to /data on Railway (volume mount) for persistence
OPENCLAW_WORKSPACE_DIR=/data/workspace

# -----------------------------------------------------------------------------
# RECOMMENDED VARIABLES
# -----------------------------------------------------------------------------

# Authentication token for the openclaw gateway and Control UI
# For Railway: Use ${{ secret(64) }} to generate a stable secret
# For local: Generate with: openssl rand -hex 32
# If not set, the wrapper will generate one (not ideal — token changes on redeploy)
OPENCLAW_GATEWAY_TOKEN=

# -----------------------------------------------------------------------------
# OPTIONAL VARIABLES (Usually don't need to change)
# -----------------------------------------------------------------------------

# Port the wrapper server listens on
# Railway sets this automatically, usually to 8080
PORT=8080

# Internal port where the gateway listens (proxied by the wrapper)
# Default: 18789
INTERNAL_GATEWAY_PORT=18789

# Internal host for the gateway
# Default: 127.0.0.1
INTERNAL_GATEWAY_HOST=127.0.0.1

# Path to the openclaw configuration file
# Default: ${OPENCLAW_STATE_DIR}/openclaw.json
# Leave empty to use the default
OPENCLAW_CONFIG_PATH=

# Path to the openclaw CLI entry point
# Default: /openclaw/dist/entry.js
# Leave empty unless using a custom build
OPENCLAW_ENTRY=/openclaw/dist/entry.js

# Node.js executable to use
# Default: node
# Leave empty unless you need a specific node binary
OPENCLAW_NODE=node

# Enable debug logging for wrapper token management
# Set to "true" to see detailed token resolution and sync logs
# WARNING: This logs sensitive tokens — never enable in production
# Default: not set (debug disabled)
OPENCLAW_TEMPLATE_DEBUG=

# Enable Web TUI (terminal in browser)
# Default: disabled for security
ENABLE_WEB_TUI=false

# TUI session limits (when ENABLE_WEB_TUI=true)
# Idle timeout in milliseconds (default: 5 minutes)
TUI_IDLE_TIMEOUT_MS=300000
# Max session duration in milliseconds (default: 30 minutes)
TUI_MAX_SESSION_MS=1800000

# -----------------------------------------------------------------------------
# MULTI-MODEL CONFIGURATION (for cost efficiency)
# -----------------------------------------------------------------------------
# After initial setup, configure multiple models via the /setup dashboard.
# Use a capable model for complex tasks and a cheaper one for simple chats.
#
# Example cost-efficient configurations:
#   Primary: anthropic/claude-sonnet-4     (complex coding, analysis)
#   Fallback: openai/gpt-4.1-mini         (simple chats, summaries)
#
#   Primary: openai/gpt-4.1               (default for most tasks)
#   Fallback: openai/gpt-4.1-nano         (lightweight tasks)
#
# Custom providers (Ollama, vLLM, LiteLLM) can also be added via /setup dashboard.

# -----------------------------------------------------------------------------
# RAILWAY-SPECIFIC VARIABLES (Set automatically by Railway)
# -----------------------------------------------------------------------------

# Git commit SHA - automatically set by Railway during deployment
# Do not set manually
# RAILWAY_GIT_COMMIT_SHA=

# Public domain - automatically set by Railway when public networking is enabled
# Do not set manually
# RAILWAY_PUBLIC_DOMAIN=

# -----------------------------------------------------------------------------
# NOTES
# -----------------------------------------------------------------------------
# 1. For Railway deployment, you MUST have a Volume mounted at /data
# 2. Without the volume, configuration will be lost on every redeploy
# 3. After deployment, visit https://your-app.up.railway.app/setup to configure
# 4. The setup wizard will guide you through onboarding
# 5. Set OPENCLAW_GATEWAY_TOKEN for stable auth across container rebuilds
# 6. Use the Model Config panel in /setup to configure multi-model routing
# =============================================================================
